#!/usr/bin/env python3
import argparse
import fnmatch
import hashlib
import json
import logging
import os
import re
import shutil
import subprocess
import sys
from dataclasses import asdict, dataclass
from datetime import datetime, timezone
from pathlib import Path


VERSION = "2.0.0"

# Observability: warnings are surfaced on stderr (never stdout, which carries the
# machine-readable JSON). Set MCT_DEBUG=1 for verbose/debug output.
logging.basicConfig(
    level=logging.DEBUG if os.environ.get("MCT_DEBUG") else logging.WARNING,
    format="mct: %(levelname)s: %(message)s",
    stream=sys.stderr,
)
logger = logging.getLogger("mct")
DEFAULT_POLICY = {
    "todoQueue": {
        "fileName": "TODO.md",
        "defaultExecution": "sequential",
        "allowParallelWhenIndependent": True,
        "updateCheckboxesAfterVerification": True,
        "deleteCompletedItems": False,
    }
}


@dataclass
class TodoTask:
    id: str
    slug: str
    line: int
    text: str
    clean_text: str
    done: bool
    raw: str
    tags: list[str]
    deps: list[str]
    files: list[str]
    risk: str
    blocked: bool
    group: str


def now() -> str:
    return datetime.now(timezone.utc).isoformat()


def run(cmd: list[str], cwd: Path, check: bool = False) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, cwd=str(cwd), text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, check=check)


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()
    with path.open("rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)
    return digest.hexdigest()


def find_root(start: Path) -> Path:
    current = start.resolve()
    for path in [current, *current.parents]:
        if (path / ".git").exists():
            return path
    return current


def claude_root() -> Path:
    env = os.environ.get("MCT_HOME")
    return Path(env).expanduser() if env else Path.home() / ".claude"


def source_root() -> Path | None:
    env = os.environ.get("MCT_SOURCE")
    candidates = []
    if env:
        candidates.append(Path(env).expanduser())
    candidates.extend([
        Path.cwd(),
        Path.home() / "My_Tech_House" / "skills_hub",
        Path.home() / "skills-hub",
        Path.home() / "skills_hub",
    ])
    for candidate in candidates:
        path = candidate.resolve()
        if (path / "claude" / "install.sh").exists() and (path / ".git").exists():
            return path
    return None


def load_policy() -> dict:
    policy_path = claude_root() / "policies" / "automation-policy.json"
    if not policy_path.exists():
        return DEFAULT_POLICY
    try:
        return json.loads(policy_path.read_text())
    except Exception:
        return DEFAULT_POLICY


def detect_stack(root: Path) -> dict:
    package = read_package_json(root)
    deps = {}
    deps.update(package.get("dependencies", {}))
    deps.update(package.get("devDependencies", {}))
    scripts = package.get("scripts", {})
    return {
        "packageManager": "pnpm" if (root / "pnpm-lock.yaml").exists() else "yarn" if (root / "yarn.lock").exists() else "npm",
        "hasPackageJson": bool(package),
        "react": "react" in deps,
        "nextjs": "next" in deps or any((root / name).exists() for name in ("next.config.js", "next.config.mjs", "next.config.ts")),
        "vite": "vite" in deps or any((root / name).exists() for name in ("vite.config.js", "vite.config.ts", "vite.config.mjs")),
        "typescript": (root / "tsconfig.json").exists() or "typescript" in deps,
        "tailwind": any((root / name).exists() for name in ("tailwind.config.js", "tailwind.config.ts", "tailwind.config.mjs")),
        "playwright": "@playwright/test" in deps or "playwright" in deps or (root / "playwright.config.ts").exists() or (root / "playwright.config.js").exists(),
        "scripts": sorted(scripts.keys()),
    }


def default_config(root: Path) -> dict:
    stack = detect_stack(root)
    return {
        "version": VERSION,
        "generatedAt": now(),
        "stack": stack,
        "autonomy": {
            "routineDecisions": "auto",
            "askBefore": ["destructive changes", "product-defining UX choices", "credentials", "paid/external account changes"],
            "commitPerVerifiedTodo": True,
            "pushAutomatically": False,
        },
        "verification": {
            "requireBrowserProofForUiTodos": True,
            "requireReactDoctorForReactTodos": True,
            "requireCommitForTodoWorkflow": True,
            "typecheckScripts": [name for name in ("typecheck", "tsc") if name in stack["scripts"]],
            "testScripts": [name for name in ("test", "test:unit", "e2e", "test:e2e") if name in stack["scripts"]],
        },
    }


def load_config(root: Path) -> dict:
    path = config_path(root)
    if not path.exists():
        return default_config(root)
    try:
        config = json.loads(path.read_text())
    except Exception:
        return default_config(root)
    base = default_config(root)
    for key, value in base.items():
        config.setdefault(key, value)
    config.setdefault("verification", {}).update({k: config.get("verification", {}).get(k, v) for k, v in base["verification"].items()})
    config.setdefault("autonomy", {}).update({k: config.get("autonomy", {}).get(k, v) for k, v in base["autonomy"].items()})
    return config


def write_config(root: Path, force: bool = False) -> Path:
    path = config_path(root)
    path.parent.mkdir(parents=True, exist_ok=True)
    if force or not path.exists():
        path.write_text(json.dumps(default_config(root), indent=2, sort_keys=True) + "\n")
    return path


def state_path(root: Path) -> Path:
    return root / ".mct" / "state.json"


def receipt_dir(root: Path) -> Path:
    return root / ".mct" / "receipts"


def proof_dir(root: Path) -> Path:
    return root / ".mct" / "browser-proof"


def config_path(root: Path) -> Path:
    return root / ".mct" / "config.json"


def default_state() -> dict:
    return {"version": VERSION, "tasks": {}, "runs": [], "checkHistory": []}


def load_state(root: Path) -> dict:
    path = state_path(root)
    if not path.exists():
        return default_state()
    try:
        state = json.loads(path.read_text())
    except Exception:
        return default_state()
    state.setdefault("version", VERSION)
    state.setdefault("tasks", {})
    state.setdefault("runs", [])
    state.setdefault("checkHistory", [])
    return state


def save_state(root: Path, state: dict) -> None:
    path = state_path(root)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(state, indent=2, sort_keys=True) + "\n")


def clean_task_text(text: str) -> str:
    text = re.sub(r"#[-A-Za-z0-9_]+", "", text)
    text = re.sub(r"\b(files|depends):[^\]]+?(?=\s+\w+:|$)", "", text)
    return re.sub(r"\s+", " ", text).strip()


def slugify(text: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "-", clean_task_text(text).lower()).strip("-")
    return slug[:48] or "task"


def task_id(text: str) -> str:
    slug = slugify(text)
    digest = hashlib.sha1(text.encode()).hexdigest()[:8]
    return f"{slug}-{digest}"


def parse_meta(text: str, key: str) -> list[str]:
    match = re.search(rf"\b{key}:([^\]#]+?)(?=\s+#|\s+\w+:|$)", text)
    if not match:
        return []
    return [item.strip() for item in re.split(r"[, ]+", match.group(1)) if item.strip()]


def infer_risk(text: str, files: list[str], deps: list[str], blocked: bool) -> str:
    lower = text.lower()
    risky_words = ("auth", "payment", "security", "database", "migration", "schema", "routing", "api", "deploy")
    if blocked or deps or any(word in lower for word in risky_words):
        return "high"
    if len(files) > 2 or any(file.endswith((".ts", ".tsx", ".js", ".jsx")) for file in files):
        return "medium"
    return "low"


def parse_todo(root: Path, policy: dict) -> tuple[Path | None, list[TodoTask]]:
    path = root / policy.get("todoQueue", {}).get("fileName", "TODO.md")
    if not path.exists():
        return None, []

    tasks: list[TodoTask] = []
    for idx, line in enumerate(path.read_text(errors="ignore").splitlines(), start=1):
        match = re.match(r"^(\s*)[-*]\s+\[([ xX])\]\s+(.+?)\s*$", line)
        if not match:
            continue
        done = match.group(2).lower() == "x"
        text = match.group(3).strip()
        tags = [part[1:] for part in re.findall(r"#[A-Za-z0-9_-]+", text)]
        deps = parse_meta(text, "depends")
        files = parse_meta(text, "files")
        blocked = "blocked" in tags or re.search(r"\bblocked\b", text, re.IGNORECASE) is not None
        group = tags[0] if tags else "default"
        tasks.append(TodoTask(
            id=task_id(text),
            slug=slugify(text),
            line=idx,
            text=text,
            clean_text=clean_task_text(text),
            done=done,
            raw=line,
            tags=tags,
            deps=deps,
            files=files,
            risk=infer_risk(text, files, deps, blocked),
            blocked=blocked,
            group=group,
        ))
    return path, tasks


def resolve_task(tasks: list[TodoTask], query: str) -> TodoTask | None:
    query_slug = slugify(query)
    for task in tasks:
        if query in (task.id, task.slug) or task.id.startswith(query) or task.slug.startswith(query_slug):
            return task
    matches = [task for task in tasks if query.lower() in task.text.lower() or query_slug in task.slug]
    return matches[0] if len(matches) == 1 else None


def dependency_analysis(tasks: list[TodoTask]) -> dict:
    by_id = {task.id: task for task in tasks}
    by_slug = {task.slug: task for task in tasks}
    missing: dict[str, list[str]] = {}
    graph: dict[str, list[str]] = {}

    for task in tasks:
        resolved: list[str] = []
        for dep in task.deps:
            target = by_id.get(dep) or by_slug.get(dep) or next((t for t in tasks if t.id.startswith(dep) or t.slug.startswith(dep)), None)
            if target:
                resolved.append(target.id)
            else:
                missing.setdefault(task.id, []).append(dep)
        graph[task.id] = resolved

    cycles: list[list[str]] = []
    visiting: set[str] = set()
    visited: set[str] = set()
    stack: list[str] = []

    def visit(node: str) -> None:
        if node in visited:
            return
        if node in visiting:
            start = stack.index(node) if node in stack else 0
            cycles.append(stack[start:] + [node])
            return
        visiting.add(node)
        stack.append(node)
        for dep in graph.get(node, []):
            visit(dep)
        stack.pop()
        visiting.remove(node)
        visited.add(node)

    for task_id_value in graph:
        visit(task_id_value)

    return {"graph": graph, "missing": missing, "cycles": cycles}


def git_files(root: Path, staged: bool = False, since: str | None = None) -> list[str]:
    if not (root / ".git").exists():
        return []
    cmd = ["git", "diff", "--name-only"]
    if staged:
        cmd.insert(2, "--cached")
    elif since:
        cmd.extend([since])
    proc = run(cmd, root)
    if proc.returncode != 0:
        return []
    return [line.strip() for line in proc.stdout.splitlines() if line.strip()]


def git_status_files(root: Path) -> list[str]:
    if not (root / ".git").exists():
        return []
    proc = run(["git", "status", "--porcelain"], root)
    if proc.returncode != 0:
        return []
    return [line for line in proc.stdout.splitlines() if line.strip()]


def commit_subject(task: TodoTask | None, summary: str | None = None) -> str:
    base = summary or (task.clean_text if task else "update project")
    base = re.sub(r"\s+", " ", base).strip().rstrip(".")
    lower = base.lower()
    if lower.startswith(("fix ", "add ", "update ", "remove ", "refactor ", "docs ")):
        prefix = "chore"
        if lower.startswith("fix "):
            prefix = "fix"
        elif lower.startswith("add "):
            prefix = "feat"
        elif lower.startswith("update "):
            prefix = "chore"
        elif lower.startswith("remove "):
            prefix = "chore"
        elif lower.startswith("refactor "):
            prefix = "refactor"
        elif lower.startswith("docs "):
            prefix = "docs"
        subject = f"{prefix}: {base[0].lower() + base[1:] if base else base}"
    else:
        prefix = "docs" if task and "docs" in task.tags else "chore"
        if task and ("bug" in task.tags or "fix" in task.tags):
            prefix = "fix"
        if task and ("feature" in task.tags or "feat" in task.tags):
            prefix = "feat"
        subject = f"{prefix}: {base}"
    return subject[:72]


def commit_body(task: TodoTask | None, checks: list[str], skipped: list[str], receipt_path: Path | None) -> str:
    lines = []
    if task:
        lines.append(f"Task: {task.clean_text}")
        lines.append(f"Task-ID: {task.id}")
    if checks:
        lines.append("Checks: " + ", ".join(checks))
    if skipped:
        lines.append("Skipped checks: " + "; ".join(skipped))
    if receipt_path:
        lines.append(f"Receipt: {receipt_path}")
    return "\n".join(lines)


def git_commit(root: Path, subject: str, body: str, include_all: bool) -> dict:
    if not (root / ".git").exists():
        return {"ok": False, "reason": "not a git repository"}
    status = git_status_files(root)
    if not status:
        return {"ok": False, "reason": "no changes to commit"}
    if include_all:
        add = run(["git", "add", "-A"], root)
        if add.returncode != 0:
            return {"ok": False, "reason": add.stderr.strip() or "git add failed"}
        run(["git", "reset", "-q", "--", ".mct"], root)
    staged = git_files(root, staged=True)
    if not staged:
        return {"ok": False, "reason": "no staged changes; use --all or stage files first"}
    cmd = ["git", "commit", "-m", subject]
    if body:
        cmd.extend(["-m", body])
    proc = subprocess.run(cmd, cwd=str(root), text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    sha = ""
    if proc.returncode == 0:
        head = run(["git", "rev-parse", "HEAD"], root)
        if head.returncode == 0:
            sha = head.stdout.strip()
    return {
        "ok": proc.returncode == 0,
        "sha": sha,
        "subject": subject,
        "body": body,
        "stdout": proc.stdout.strip(),
        "stderr": proc.stderr.strip(),
    }


def ci_changed_files(root: Path) -> list[str]:
    base_ref = os.environ.get("GITHUB_BASE_REF")
    if base_ref:
        run(["git", "fetch", "origin", base_ref, "--depth=1"], root)
        proc = run(["git", "diff", "--name-only", f"origin/{base_ref}...HEAD"], root)
        if proc.returncode == 0 and proc.stdout.strip():
            return [line.strip() for line in proc.stdout.splitlines() if line.strip()]
    proc = run(["git", "diff", "--name-only", "HEAD~1...HEAD"], root)
    if proc.returncode == 0:
        return [line.strip() for line in proc.stdout.splitlines() if line.strip()]
    return []


def files_for_verify(root: Path, mode: str) -> list[str]:
    if mode == "pre-commit":
        return git_files(root, staged=True)
    if mode == "ci":
        return ci_changed_files(root)
    files = git_files(root)
    return files or ci_changed_files(root)


def classify_files(files: list[str]) -> dict:
    surfaces = {"react": [], "ui": [], "typescript": [], "docs": [], "config": [], "tests": [], "other": []}
    for file in files:
        lower = file.lower()
        matched = False
        if fnmatch.fnmatch(lower, "*.tsx") or fnmatch.fnmatch(lower, "*.jsx"):
            surfaces["react"].append(file); matched = True
        if lower.endswith((".css", ".scss", ".sass")) or "tailwind.config" in lower:
            surfaces["ui"].append(file); matched = True
        if lower.endswith((".ts", ".tsx")):
            surfaces["typescript"].append(file); matched = True
        if lower.endswith((".md", ".mdx")):
            surfaces["docs"].append(file); matched = True
        if any(name in lower for name in ("package.json", "tsconfig", "next.config", "vite.config", "eslint", "biome", "prettier")):
            surfaces["config"].append(file); matched = True
        if re.search(r"(__tests__|\.test\.|\.spec\.)", lower):
            surfaces["tests"].append(file); matched = True
        if not matched:
            surfaces["other"].append(file)
    return {key: value for key, value in surfaces.items() if value}


def recommend_checks(root: Path, surfaces: dict) -> list[str]:
    checks = ["diff-review"]
    if "react" in surfaces:
        checks.append("react-doctor-diff")
    if "typescript" in surfaces and (len(surfaces.get("typescript", [])) > 1 or "config" in surfaces):
        checks.append("typecheck-if-script-exists")
    if "ui" in surfaces or "react" in surfaces:
        checks.append("ui-check-if-visible-change")
    if "config" in surfaces:
        checks.append("package-script-sanity")
    if (root / "package.json").exists() and ("react" in surfaces or "typescript" in surfaces):
        checks.append("targeted-tests-if-script-exists")
    return list(dict.fromkeys(checks))


def is_ui_task(task: TodoTask) -> bool:
    signals = {"ui", "ux", "frontend", "react", "style", "layout", "responsive", "animation", "component", "visual"}
    lower_text = task.text.lower()
    lower_files = [file.lower() for file in task.files]
    if any(tag.lower() in signals for tag in task.tags):
        return True
    if any(signal in lower_text for signal in signals):
        return True
    return any(
        file.endswith((".tsx", ".jsx", ".css", ".scss", ".sass", ".mdx"))
        or "tailwind.config" in file
        or "/app/" in file
        or "/components/" in file
        for file in lower_files
    )


def is_react_task(task: TodoTask) -> bool:
    lower_text = task.text.lower()
    lower_files = [file.lower() for file in task.files]
    return (
        "react" in [tag.lower() for tag in task.tags]
        or "react" in lower_text
        or any(file.endswith((".tsx", ".jsx")) for file in lower_files)
    )


def is_api_task(task: TodoTask) -> bool:
    lower = task.text.lower()
    return any(signal in lower or signal in task.tags for signal in ("api", "route", "endpoint", "server", "backend"))


def is_security_task(task: TodoTask) -> bool:
    lower = task.text.lower()
    return any(signal in lower or signal in task.tags for signal in ("auth", "security", "payment", "permission", "webhook"))


def task_required_checks(task: TodoTask, root: Path) -> list[str]:
    required = []
    if is_ui_task(task):
        required.append("browser-proof")
    if is_react_task(task) and is_react_project(root):
        required.append("react-doctor")
    if is_api_task(task):
        required.append("api-behavior-check")
    if is_security_task(task):
        required.append("negative-path-check")
    if any(file.endswith((".ts", ".tsx")) for file in task.files) and package_has_script(root, "typecheck"):
        required.append("typecheck")
    return list(dict.fromkeys(required))


# Map the recognized check tokens to their canonical required-check name. A token
# only resolves if it equals the canonical name or one of these exact aliases —
# never by loose substring matching over a free-text blob.
CANONICAL_CHECK_ALIASES = {
    "diff-review": ("diff-review", "diff", "review"),
    "browser-proof": ("browser-proof", "browser", "playwright", "chrome", "screenshot", "visual", "responsive", "ui-check"),
    "react-doctor": ("react-doctor", "reactdoctor", "react-doctor-diff"),
    "api-behavior-check": ("api-behavior-check", "api-behavior", "api-check"),
    "negative-path-check": ("negative-path-check", "negative-path", "negativepath"),
    "typecheck": ("typecheck", "tsc", "type-check"),
    "test": ("test", "tests", "unit-test", "unit-tests", "targeted-tests"),
}

# Required checks that can be executed deterministically. For these a bare
# self-reported claim is NOT accepted as proof: they must be executed (recorded
# with executed=true and a pass result) or explicitly skipped with a reason.
AUTO_EXECUTABLE_CHECKS = {"typecheck", "react-doctor", "test"}


def canonical_check_name(token: str) -> str:
    token = (token or "").strip().lower()
    for canon, aliases in CANONICAL_CHECK_ALIASES.items():
        if token == canon or token in aliases:
            return canon
    return token


def parse_check_token(item: str) -> tuple[str, str]:
    """Split a `--check` token into (canonical_name, detail).

    Accepts `name`, `name=detail`, or `name:detail`. Only a leading single token
    (letters/digits/_/-) before a `=`/`:` is treated as the name.
    """
    raw = (item or "").strip()
    match = re.match(r"^([A-Za-z0-9_-]+)\s*[=:]\s*(.+)$", raw, re.DOTALL)
    if match:
        return canonical_check_name(match.group(1)), match.group(2).strip()
    return canonical_check_name(raw), ""


def parse_skip_token(item: str) -> tuple[str, str]:
    """A skip must be `name=reason` (or `name:reason`) with a non-empty reason.

    A bare free-text skip resolves to no known check name and an empty reason, so
    it cannot satisfy any required check.
    """
    return parse_check_token(item)


def requirement_satisfied(
    required: str,
    provided: list[tuple[str, str]],
    skips: list[tuple[str, str]],
    executed: list[dict],
    artifact_ok: bool,
) -> bool:
    # An executed, passing check is always sufficient.
    if any(entry.get("name") == required and entry.get("result") == "pass" for entry in executed):
        return True
    # An explicit, named skip carrying a concrete reason.
    if any(name == required and reason for name, reason in skips):
        return True
    # Browser proof is satisfied only by a real artifact (verified separately),
    # never by a free-text evidence string.
    if required == "browser-proof":
        return bool(artifact_ok)
    # Deterministically runnable checks must be executed, not merely claimed.
    if required in AUTO_EXECUTABLE_CHECKS:
        return False
    # Other checks (negative-path-check, api-behavior-check, diff-review) accept an
    # explicit, named self-report that carries concrete detail.
    return any(name == required and detail for name, detail in provided)


def unmet_required_checks(
    task: TodoTask,
    root: Path,
    checks: list[str] | None,
    skipped: list[str] | None,
    executed: list[dict] | None = None,
    artifact_ok: bool = False,
) -> list[str]:
    provided = [parse_check_token(item) for item in (checks or [])]
    skips = [parse_skip_token(item) for item in (skipped or [])]
    executed = executed or []
    return [
        required
        for required in task_required_checks(task, root)
        if not requirement_satisfied(required, provided, skips, executed, artifact_ok)
    ]


# Backwards-compatible name retained for any external callers.
def missing_required_checks(task: TodoTask, root: Path, checks: list[str] | None, skipped: list[str] | None) -> list[str]:
    return unmet_required_checks(task, root, checks, skipped)


def unmet_checks_message(unmet: list[str], artifact_reason: str = "") -> str:
    parts = ["cannot mark TODO done: unsatisfied required checks: " + ", ".join(unmet) + "."]
    if "browser-proof" in unmet:
        extra = f" (evidence rejected: {artifact_reason})" if artifact_reason else ""
        parts.append(
            "browser-proof needs a real artifact" + extra
            + ": save a screenshot/proof file and pass --browser-evidence "
            "'tool=playwright | url=... | viewport=1440x900 | screenshot=.mct/shot.png | result=pass', "
            "or record --skipped-check browser-proof=<concrete reason>."
        )
    for req in unmet:
        if req in AUTO_EXECUTABLE_CHECKS:
            parts.append(f"{req} must be executed: pass --run-check {req} (or --skipped-check {req}=<reason>).")
        elif req != "browser-proof":
            parts.append(f"{req} needs a named attestation: --check {req}=<concrete evidence> (or --skipped-check {req}=<reason>).")
    return " ".join(parts)


def browser_check_names(checks: list[str] | None) -> list[str]:
    return [
        check for check in (checks or [])
        if re.search(r"(playwright|chrome|browser|screenshot|responsive|visual)", check, re.IGNORECASE)
    ]


def parse_browser_evidence(items: list[str] | None) -> list[dict]:
    evidence = []
    for item in items or []:
        parts = [part.strip() for part in re.split(r"\s*\|\s*", item) if part.strip()]
        entry = {"raw": item}
        for part in parts:
            if "=" in part:
                key, value = part.split("=", 1)
                entry[key.strip().lower()] = value.strip()
        evidence.append(entry)
    return evidence


def valid_browser_evidence(items: list[str] | None) -> tuple[bool, str]:
    parsed = parse_browser_evidence(items)
    if not parsed:
        return False, "missing --browser-evidence"
    for item in parsed:
        raw = item.get("raw", "").strip()
        result = item.get("result", "").lower()
        target = item.get("url") or item.get("file") or item.get("screenshot") or item.get("test") or item.get("command") or item.get("proof")
        covered_flow = item.get("viewport") or item.get("flow") or item.get("assertion") or item.get("page")
        if len(raw) < 12:
            return False, "browser evidence is too vague"
        if not result:
            return False, "browser evidence must include result=pass"
        if result not in {"pass", "passed", "ok", "success"}:
            return False, f"browser evidence did not pass: {raw}"
        if not target and not re.search(r"(https?://|localhost|127\.0\.0\.1|file=|screenshot=|test=|command=|proof=)", raw, re.IGNORECASE):
            return False, f"browser evidence lacks a target: {raw}"
        if not covered_flow:
            return False, f"browser evidence lacks viewport, flow, assertion, or page: {raw}"
    return True, ""


def browser_artifact_issue(root: Path, evidence: list[dict]) -> str:
    for item in evidence:
        screenshot = item.get("screenshot")
        if screenshot:
            path = Path(screenshot).expanduser()
            if not path.is_absolute():
                path = root / path
            if not path.exists():
                return f"screenshot artifact is missing: {screenshot}"
        proof = item.get("proof")
        if proof:
            path = Path(proof).expanduser()
            if not path.is_absolute():
                path = root / path
            if not path.exists():
                return f"browser proof artifact is missing: {proof}"
    return ""


_IMAGE_MAGIC = (
    b"\x89PNG\r\n\x1a\n",  # PNG
    b"\xff\xd8\xff",        # JPEG
    b"GIF87a",
    b"GIF89a",
    b"BM",                  # BMP
)


def is_valid_image(path: Path) -> bool:
    try:
        with path.open("rb") as handle:
            header = handle.read(16)
    except OSError:
        return False
    if any(header.startswith(magic) for magic in _IMAGE_MAGIC):
        return True
    return header[:4] == b"RIFF" and header[8:12] == b"WEBP"  # WebP


def resolve_artifact(root: Path, value: str) -> Path:
    path = Path(value).expanduser()
    return path if path.is_absolute() else root / path


def browser_artifact_ok(root: Path, evidence: list[dict]) -> tuple[bool, str]:
    """A real browser artifact must exist, be non-empty, and (for a screenshot)
    be a valid image. Returns (ok, reason_if_not_ok)."""
    found = False
    for item in evidence:
        screenshot = item.get("screenshot")
        if screenshot:
            path = resolve_artifact(root, screenshot)
            if not path.exists():
                return False, f"screenshot artifact is missing: {screenshot}"
            if path.stat().st_size == 0:
                return False, f"screenshot artifact is empty: {screenshot}"
            if not is_valid_image(path):
                return False, f"screenshot artifact is not a valid image: {screenshot}"
            found = True
        proof = item.get("proof")
        if proof:
            path = resolve_artifact(root, proof)
            if not path.exists():
                return False, f"browser proof artifact is missing: {proof}"
            if path.stat().st_size == 0:
                return False, f"browser proof artifact is empty: {proof}"
            found = True
    if not found:
        return False, "browser evidence references no real artifact (need screenshot= or proof= pointing to an existing file)"
    return True, ""


def run_named_check(root: Path, name: str) -> dict:
    """Execute a deterministic check and record its real exit code.

    Returns a structured result. `executed` is False when no runner is available
    for the check in this project (e.g. no typecheck script), in which case the
    check is neither pass nor fail and cannot satisfy a requirement on its own.
    """
    canon = canonical_check_name(name)
    command: list[str] | None = None
    if canon == "react-doctor":
        if shutil.which("npx"):
            command = ["npx", "-y", "react-doctor@latest", ".", "--diff"]
    elif canon in ("typecheck", "test"):
        if package_has_script(root, canon):
            if (root / "pnpm-lock.yaml").exists():
                command = ["pnpm", "run", canon]
            elif (root / "yarn.lock").exists():
                command = ["yarn", canon]
            else:
                command = ["npm", "run", canon]
    if command is None:
        logger.warning("no runner available for check %r in %s", canon, root)
        return {
            "name": canon,
            "executed": False,
            "result": "unavailable",
            "reason": f"no runner available for {canon} in this project",
            "at": now(),
        }
    proc = subprocess.run(command, cwd=str(root))
    return {
        "name": canon,
        "executed": True,
        "command": " ".join(command),
        "exitCode": proc.returncode,
        "result": "pass" if proc.returncode == 0 else "fail",
        "at": now(),
    }


def task_plan(tasks: list[TodoTask]) -> dict:
    deps = dependency_analysis(tasks)
    completed_ids = {task.id for task in tasks if task.done}
    open_tasks = [task for task in tasks if not task.done]
    blocked = [task for task in open_tasks if task.blocked or task.id in deps["missing"]]
    runnable = [
        task for task in open_tasks
        if task not in blocked and all(dep_id in completed_ids for dep_id in deps["graph"].get(task.id, []))
    ]

    by_file: dict[str, list[str]] = {}
    for task in runnable:
        for file in task.files:
            by_file.setdefault(file, []).append(task.id)
    overlapping = {file: ids for file, ids in by_file.items() if len(ids) > 1}

    independent = [
        task for task in runnable
        if not deps["graph"].get(task.id)
        and not any(task.id in ids for ids in overlapping.values())
        and task.risk != "high"
    ]
    dependent = [task for task in open_tasks if task not in independent and task not in blocked]
    mode = "parallel-candidates" if len(independent) > 1 else "sequential"
    next_tasks = independent[:4] if mode == "parallel-candidates" else runnable[:1]

    return {
        "mode": mode,
        "next": [asdict(task) for task in next_tasks],
        "independent": [asdict(task) for task in independent],
        "dependent_or_risky": [asdict(task) for task in dependent],
        "blocked": [asdict(task) for task in blocked],
        "overlappingFiles": overlapping,
        "dependencies": deps,
    }


def status_data(root: Path) -> dict:
    policy = load_policy()
    todo_path, tasks = parse_todo(root, policy)
    changed = git_files(root)
    staged = git_files(root, staged=True)
    surfaces = classify_files(changed or staged)
    opensrc_dir = root / "opensrc"
    return {
        "root": str(root),
        "todo": str(todo_path) if todo_path else None,
        "packageJson": str(root / "package.json") if (root / "package.json").exists() else None,
        "opensrc": {
            "exists": opensrc_dir.exists(),
            "manifest": str(opensrc_dir / "manifest.json") if (opensrc_dir / "manifest.json").exists() else None,
        },
        "tasks": [asdict(task) for task in tasks],
        "plan": task_plan(tasks),
        "changedFiles": changed,
        "stagedFiles": staged,
        "surfaces": surfaces,
        "recommendedChecks": recommend_checks(root, surfaces),
        "state": load_state(root),
    }


def load_opensrc_manifest(root: Path) -> dict:
    path = root / "opensrc" / "manifest.json"
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text())
    except Exception:
        return {}


def opensrc_package_coverage(root: Path) -> dict:
    deps = package_dependencies(root)
    manifest = load_opensrc_manifest(root)
    packages = manifest.get("packages", []) if isinstance(manifest, dict) else []
    package_by_name = {
        item.get("name"): item
        for item in packages
        if isinstance(item, dict) and item.get("name")
    }
    missing_context_files = []
    stub_context_files = []

    for name, item in sorted(package_by_name.items()):
        context_file = item.get("contextFile") or f"packages/{safe_package_filename(name)}.md"
        path = root / "opensrc" / context_file
        if not path.exists():
            missing_context_files.append(name)
            continue
        text = path.read_text(errors="ignore")
        if re.search(r"(?m)^- Pending\.\s*$", text):
            stub_context_files.append(name)

    return {
        "declaredPackages": sorted(deps),
        "manifestPackages": sorted(package_by_name),
        "missingPackages": sorted(set(deps) - set(package_by_name)),
        "extraPackages": sorted(set(package_by_name) - set(deps)),
        "missingContextFiles": missing_context_files,
        "stubContextFiles": stub_context_files,
    }


def render_status_md(data: dict) -> str:
    tasks = data["tasks"]
    open_tasks = [task for task in tasks if not task["done"]]
    lines = [
        "# MCT Status",
        "",
        f"- Root: `{data['root']}`",
        f"- package.json: `{data['packageJson']}`" if data["packageJson"] else "- package.json: not found",
        f"- opensrc: `{data['opensrc']['manifest']}`" if data["opensrc"]["manifest"] else "- opensrc: not initialized",
        f"- TODO.md: `{data['todo']}`" if data["todo"] else "- TODO.md: not found",
        f"- Tasks: {len(tasks)} total, {len(open_tasks)} open",
        f"- Mode: `{data['plan']['mode']}`",
        "",
        "## Next",
    ]
    next_tasks = data["plan"].get("next", [])
    if next_tasks:
        lines.extend([f"- `{task['id']}`: {task['clean_text']}" for task in next_tasks])
    else:
        lines.append("- No runnable task found.")
    lines.extend(["", "## Blocked"])
    blocked = data["plan"].get("blocked", [])
    lines.extend([f"- `{task['id']}`: {task['clean_text']}" for task in blocked] or ["- None"])
    lines.extend(["", "## Changed Surfaces"])
    if data["surfaces"]:
        for surface, files in data["surfaces"].items():
            lines.append(f"- {surface}: {len(files)} file(s)")
    else:
        lines.append("- None")
    lines.extend(["", "## Recommended Checks"])
    lines.extend([f"- {check}" for check in data["recommendedChecks"]] or ["- None"])
    runs = data["state"].get("runs", [])[-5:]
    lines.extend(["", "## Recent Receipts"])
    lines.extend([f"- {run.get('at')}: {run.get('summary', '')}" for run in runs] or ["- None"])
    return "\n".join(lines) + "\n"


def command_status(args: argparse.Namespace) -> int:
    data = status_data(find_root(Path.cwd()))
    if args.md:
        print(render_status_md(data))
    else:
        print(json.dumps(data, indent=2))
    return 0


def command_plan(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    data = status_data(root)
    print(json.dumps({
        "root": data["root"],
        "todo": data["todo"],
        "opensrc": data["opensrc"],
        "todoPlan": data["plan"],
        "changedSurfaces": data["surfaces"],
        "recommendedChecks": data["recommendedChecks"],
        "instructions": [
            "Read TODO.md fully before editing when todo is present.",
            "Execute sequentially unless todoPlan.mode is parallel-candidates and files do not overlap.",
            "Run per-item checks before marking TODO items complete.",
            "Write a receipt with mct receipt after each completed item or batch.",
        ],
    }, indent=2))
    return 0


def command_start(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    data = status_data(root)
    coverage = opensrc_package_coverage(root) if data["packageJson"] else {}
    required_steps = [
        "Read AGENTS.md, README.md, claude/MCT.md, and claude/CLAUDE.md when present.",
        "Inspect project state before editing.",
        "If package.json exists, run mct opensrc --fetch-metadata before normal planning.",
        "Read opensrc/manifest.json and ensure every declared package has a context file.",
        "Deep-fill official source context for task-relevant libraries before editing.",
        "If TODO.md exists, run mct status --md and mct next --claim before editing.",
        "Route work through the matching skills/subagents/checks for the changed surfaces.",
        "Run verification before mct done, then record concrete checks or skipped-check reasons.",
        "Run mct final-check --todo-log before final response.",
    ]
    payload = {
        "root": data["root"],
        "mctActivation": "required",
        "packageJson": data["packageJson"],
        "opensrc": data["opensrc"],
        "opensrcCoverage": coverage,
        "todo": data["todo"],
        "next": data["plan"].get("next", []),
        "recommendedChecks": data["recommendedChecks"],
        "requiredFirstSteps": required_steps,
    }
    if args.md:
        print("# MCT Toolkit Active\n")
        print(f"- Root: `{payload['root']}`")
        print(f"- package.json: `{payload['packageJson']}`" if payload["packageJson"] else "- package.json: not found")
        print(f"- opensrc manifest: `{payload['opensrc']['manifest']}`" if payload["opensrc"]["manifest"] else "- opensrc manifest: not initialized")
        if coverage:
            print(f"- opensrc package coverage: {len(coverage['manifestPackages'])}/{len(coverage['declaredPackages'])} declared packages in manifest")
            if coverage["missingPackages"]:
                print(f"- missing opensrc packages: {', '.join(coverage['missingPackages'])}")
            if coverage["missingContextFiles"]:
                print(f"- missing opensrc context files: {', '.join(coverage['missingContextFiles'])}")
            if coverage["stubContextFiles"]:
                print(f"- stub opensrc context files: {len(coverage['stubContextFiles'])}")
        print(f"- TODO.md: `{payload['todo']}`" if payload["todo"] else "- TODO.md: not found")
        print("\n## Execution Trace")
        for index, step in enumerate(required_steps, start=1):
            print(f"{index}. {step}")
        print("\n## Visible Agent Message")
        print("MCT toolkit active. I will inspect, refresh opensrc when package.json exists, route through TODO.md when present, verify before completion, and run final audit before stopping.")
        print("\n## Next")
        if payload["next"]:
            for task in payload["next"]:
                print(f"- `{task['id']}`: {task['clean_text']}")
        else:
            print("- No runnable TODO task found.")
        return 0
    print(json.dumps(payload, indent=2))
    return 0


def command_next(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    data = status_data(root)
    next_tasks = data["plan"].get("next", [])
    if args.claim and next_tasks:
        state = load_state(root)
        for task in next_tasks:
            state.setdefault("tasks", {}).setdefault(task["id"], {})
            state["tasks"][task["id"]].update({"status": "in_progress", "claimedAt": now(), "text": task["clean_text"]})
        save_state(root, state)
    print(json.dumps({
        "root": data["root"],
        "mode": data["plan"]["mode"],
        "next": next_tasks,
        "claim": bool(args.claim),
        "recommendedChecks": data["recommendedChecks"],
        "dependencies": data["plan"].get("dependencies", {}),
    }, indent=2))
    return 0


def command_todo_log(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    _, tasks = parse_todo(root, load_policy())
    receipts = load_receipts(root)
    receipt_by_task = {
        task_id_value: {"path": str(path.relative_to(root)), **receipt}
        for path, receipt in receipts
        for task_id_value in receipt.get("completedTasks", [])
    }
    rows = []
    for task in tasks:
        receipt = receipt_by_task.get(task.id, {})
        rows.append({
            "id": task.id,
            "status": "done" if task.done else load_state(root).get("tasks", {}).get(task.id, {}).get("status", "open"),
            "text": task.clean_text,
            "requiredChecks": task_required_checks(task, root),
            "checksRun": receipt.get("checksRun", []),
            "checksSkipped": receipt.get("checksSkipped", []),
            "browserEvidence": receipt.get("browserEvidence", []),
            "receipt": receipt.get("path"),
            "commit": (receipt.get("commit") or {}).get("sha"),
        })
    if args.md:
        print("# MCT TODO Log\n")
        for row in rows:
            print(f"- `{row['id']}` {row['status']}: {row['text']}")
            if row["requiredChecks"]:
                print(f"  - required: {', '.join(row['requiredChecks'])}")
            if row["checksRun"]:
                print(f"  - checks: {', '.join(row['checksRun'])}")
            if row["checksSkipped"]:
                print(f"  - skipped: {'; '.join(row['checksSkipped'])}")
            if row["commit"]:
                print(f"  - commit: {row['commit']}")
            if row["receipt"]:
                print(f"  - receipt: {row['receipt']}")
    else:
        print(json.dumps({"root": str(root), "tasks": rows}, indent=2))
    return 0


def command_branch(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    if not (root / ".git").exists():
        raise SystemExit("not a git repository")
    name = args.name
    if not name:
        _, tasks = parse_todo(root, load_policy())
        plan = task_plan(tasks)
        next_tasks = plan.get("next", [])
        if not next_tasks:
            raise SystemExit("no runnable TODO task found for branch name")
        name = next_tasks[0]["slug"]
    branch = name if name.startswith(args.prefix) else f"{args.prefix}{slugify(name)}"
    proc = subprocess.run(["git", "switch", "-c", branch], cwd=str(root), text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    result = {"ok": proc.returncode == 0, "branch": branch, "stdout": proc.stdout.strip(), "stderr": proc.stderr.strip()}
    print(json.dumps(result, indent=2))
    return 0 if result["ok"] else 1


def command_classify(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    files = args.files or git_files(root, staged=args.staged)
    surfaces = classify_files(files)
    print(json.dumps({"root": str(root), "files": files, "surfaces": surfaces, "recommendedChecks": recommend_checks(root, surfaces)}, indent=2))
    return 0


def command_config(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    if args.init:
        path = write_config(root, force=args.force)
        print(json.dumps({"ok": True, "config": str(path), "data": load_config(root)}, indent=2))
        return 0
    print(json.dumps(load_config(root), indent=2))
    return 0


def append_receipt(root: Path, receipt: dict) -> Path:
    receipt_dir(root).mkdir(parents=True, exist_ok=True)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    path = receipt_dir(root) / f"{stamp}.json"
    path.write_text(json.dumps(receipt, indent=2, sort_keys=True) + "\n")
    state = load_state(root)
    state.setdefault("runs", []).append({"at": receipt["at"], "receipt": str(path.relative_to(root)), "summary": receipt.get("summary", ""), "completedTasks": receipt.get("completedTasks", [])})
    if receipt.get("checksRun") or receipt.get("checksSkipped") or receipt.get("browserEvidence") or receipt.get("risks"):
        state.setdefault("checkHistory", []).append({
            "at": receipt["at"],
            "summary": receipt.get("summary", ""),
            "checksRun": receipt.get("checksRun", []),
            "checksSkipped": receipt.get("checksSkipped", []),
            "browserEvidence": receipt.get("browserEvidence", []),
            "risks": receipt.get("risks", []),
        })
    save_state(root, state)
    return path


def update_receipt(path: Path, updates: dict) -> None:
    try:
        receipt = json.loads(path.read_text())
    except Exception:
        return
    receipt.update(updates)
    path.write_text(json.dumps(receipt, indent=2, sort_keys=True) + "\n")


def load_receipts(root: Path) -> list[tuple[Path, dict]]:
    receipts = []
    directory = receipt_dir(root)
    if not directory.exists():
        return receipts
    for path in sorted(directory.glob("*.json")):
        try:
            receipts.append((path, json.loads(path.read_text())))
        except Exception:
            continue
    return receipts


def commit_exists(root: Path, sha: str | None) -> bool:
    if not sha:
        return False
    proc = run(["git", "cat-file", "-e", f"{sha}^{{commit}}"], root)
    return proc.returncode == 0


def command_receipt(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    receipt = {
        "at": now(),
        "summary": args.summary or "",
        "completedTasks": args.completed_task or [],
        "checksRun": args.check or [],
        "checksSkipped": args.skipped_check or [],
        "browserEvidence": parse_browser_evidence(args.browser_evidence),
        "risks": args.risk or [],
        "changedFiles": git_files(root),
        "stagedFiles": git_files(root, staged=True),
    }
    path = append_receipt(root, receipt)
    print(json.dumps({"receipt": str(path), **receipt}, indent=2))
    return 0


def command_browser_proof(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    if not (args.url or args.test or args.screenshot or args.command):
        raise SystemExit("browser-proof requires at least one target: --url, --test, --screenshot, or --command")
    if args.result.lower() not in {"pass", "passed", "ok", "success", "fail", "failed"}:
        raise SystemExit("--result must be pass or fail")
    screenshot_meta = None
    if args.screenshot:
        screenshot_path = Path(args.screenshot).expanduser()
        if not screenshot_path.is_absolute():
            screenshot_path = root / screenshot_path
        if not screenshot_path.exists():
            raise SystemExit(f"screenshot not found: {screenshot_path}")
        if screenshot_path.stat().st_size == 0:
            raise SystemExit(f"screenshot is empty: {screenshot_path}")
        if not is_valid_image(screenshot_path):
            raise SystemExit(f"screenshot is not a valid image (PNG/JPEG/GIF/WebP/BMP): {screenshot_path}")
        screenshot_meta = {
            "path": str(screenshot_path),
            "sha256": sha256_file(screenshot_path),
            "bytes": screenshot_path.stat().st_size,
        }
    proof = {
        "at": now(),
        "tool": args.tool,
        "url": args.url,
        "test": args.test,
        "command": args.command,
        "viewport": args.viewport,
        "flow": args.flow,
        "assertion": args.assertion,
        "result": args.result,
        "screenshot": screenshot_meta,
    }
    proof_dir(root).mkdir(parents=True, exist_ok=True)
    proof_id = hashlib.sha1(json.dumps(proof, sort_keys=True).encode()).hexdigest()[:12]
    path = proof_dir(root) / f"{proof_id}.json"
    path.write_text(json.dumps(proof, indent=2, sort_keys=True) + "\n")
    evidence = f"tool={args.tool}"
    if args.url:
        evidence += f" | url={args.url}"
    if args.test:
        evidence += f" | test={args.test}"
    if args.command:
        evidence += f" | command={args.command}"
    if args.viewport:
        evidence += f" | viewport={args.viewport}"
    if args.flow:
        evidence += f" | flow={args.flow}"
    if args.assertion:
        evidence += f" | assertion={args.assertion}"
    if screenshot_meta:
        evidence += f" | screenshot={screenshot_meta['path']}"
    evidence += f" | proof={path.relative_to(root)} | result={args.result}"
    result = {"ok": args.result.lower() in {"pass", "passed", "ok", "success"}, "proof": str(path), "browserEvidence": evidence}
    print(json.dumps(result, indent=2))
    return 0 if result["ok"] else 1


def update_todo_checkbox(todo_path: Path, line_no: int) -> None:
    lines = todo_path.read_text(errors="ignore").splitlines()
    index = line_no - 1
    if index < 0 or index >= len(lines):
        raise SystemExit(f"line {line_no} not found in {todo_path}")
    lines[index] = re.sub(r"^(\s*[-*]\s+\[)[ xX](\]\s+)", r"\1x\2", lines[index])
    todo_path.write_text("\n".join(lines) + "\n")


def command_run_check(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    results = [run_named_check(root, name) for name in args.name]
    state = load_state(root)
    state.setdefault("checkHistory", []).extend(results)
    save_state(root, state)
    rc = 1 if any(r.get("executed") and r.get("result") != "pass" for r in results) else 0
    print(json.dumps({"results": results, "ok": rc == 0}, indent=2))
    return rc


def command_done(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    has_input = bool(args.check or args.skipped_check or args.browser_evidence or getattr(args, "run_check", None))
    if not has_input:
        raise SystemExit(
            "mct done requires at least one --check, --run-check, --skipped-check, or --browser-evidence before marking a TODO complete"
        )
    policy = load_policy()
    todo_path, tasks = parse_todo(root, policy)
    if not todo_path:
        raise SystemExit("TODO.md not found")
    task = resolve_task(tasks, args.task)
    if not task:
        raise SystemExit(f"Could not resolve task: {args.task}")

    # Execute any checks the caller asked us to run for real, and record them.
    executed_results = [run_named_check(root, name) for name in (getattr(args, "run_check", None) or [])]
    if executed_results:
        state = load_state(root)
        state.setdefault("checkHistory", []).extend(executed_results)
        save_state(root, state)
    failed = [r for r in executed_results if r.get("executed") and r.get("result") != "pass"]
    if failed:
        raise SystemExit(
            "cannot mark TODO done: executed check(s) failed: "
            + ", ".join(f"{r['name']} (exit {r.get('exitCode')})" for r in failed)
        )

    # Browser proof must reference a real artifact, not just a formatted string.
    evidence = parse_browser_evidence(args.browser_evidence)
    artifact_ok, artifact_reason = False, ""
    if evidence:
        shape_ok, shape_reason = valid_browser_evidence(args.browser_evidence)
        if shape_ok:
            artifact_ok, artifact_reason = browser_artifact_ok(root, evidence)
        else:
            artifact_reason = shape_reason

    unmet = unmet_required_checks(task, root, args.check, args.skipped_check, executed_results, artifact_ok)
    if unmet:
        raise SystemExit(unmet_checks_message(unmet, artifact_reason))

    receipt = {
        "at": now(),
        "summary": args.summary or f"completed {task.clean_text}",
        "completedTasks": [task.id],
        "checksRun": args.check or [],
        "checksSkipped": args.skipped_check or [],
        "executedChecks": executed_results,
        "browserEvidence": evidence,
        "risks": args.risk or [],
        "changedFiles": git_files(root),
        "stagedFiles": git_files(root, staged=True),
    }

    # Commit BEFORE flipping the checkbox so a failed commit never leaves the
    # TODO marked done-but-uncommitted.
    commit_result = None
    commit_payload = None
    if args.commit:
        subject = args.message or commit_subject(task, args.summary)
        body = commit_body(task, args.check or [], args.skipped_check or [], None)
        commit_result = git_commit(root, subject, body, args.all)
        if commit_result.get("ok"):
            commit_payload = {"commit": {"sha": commit_result.get("sha"), "subject": commit_result.get("subject")}}
        elif not args.allow_no_commit:
            raise SystemExit(
                "commit failed; TODO left unchanged: "
                + (commit_result.get("reason") or commit_result.get("stderr") or "unknown error")
            )

    # The task is genuinely complete past this point: flip the checkbox, write the
    # receipt, and persist state.
    if not task.done:
        update_todo_checkbox(todo_path, task.line)
    if commit_payload:
        receipt.update(commit_payload)
    receipt_path = append_receipt(root, receipt)
    state = load_state(root)
    task_state = state.setdefault("tasks", {}).setdefault(task.id, {})
    task_state.update({
        "status": "done",
        "completedAt": now(),
        "text": task.clean_text,
        "checks": args.check or [],
        "executedChecks": executed_results,
        "browserEvidence": evidence,
    })
    if commit_payload:
        task_state["commit"] = commit_payload["commit"]
        for run_item in state.get("runs", []):
            if run_item.get("receipt") == str(receipt_path.relative_to(root)):
                run_item["commit"] = commit_payload["commit"]
    save_state(root, state)
    print(json.dumps({"done": asdict(task), "todoUpdated": str(todo_path), "receipt": str(receipt_path), "commit": commit_result}, indent=2))
    return 0


def command_commit(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    task = None
    if args.task:
        _, tasks = parse_todo(root, load_policy())
        task = resolve_task(tasks, args.task)
        if not task:
            raise SystemExit(f"Could not resolve task: {args.task}")
    subject = args.message or commit_subject(task, args.summary)
    body = commit_body(task, args.check or [], args.skipped_check or [], None)
    result = git_commit(root, subject, body, args.all)
    print(json.dumps(result, indent=2))
    return 0 if result.get("ok") else 1


def has_secret_in_staged(root: Path) -> tuple[bool, str]:
    files = git_files(root, staged=True)
    secret_file = re.compile(r"(^|/)\.env$|\.pem$|\.key$|id_rsa|id_ed25519")
    for file in files:
        if secret_file.search(file):
            return True, f"possible secret/private key file staged: {file}"
    proc = run(["git", "diff", "--cached"], root)
    if proc.returncode == 0 and re.search(r"sk-[A-Za-z0-9_-]{20,}|-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----", proc.stdout):
        return True, "possible secret found in staged diff"
    return False, ""


def package_has_script(root: Path, name: str) -> bool:
    path = root / "package.json"
    if not path.exists():
        return False
    try:
        package = json.loads(path.read_text())
    except Exception:
        return False
    return name in package.get("scripts", {})


def read_package_json(root: Path) -> dict:
    path = root / "package.json"
    if not path.exists():
        return {}
    try:
        return json.loads(path.read_text())
    except Exception:
        return {}


def package_dependencies(root: Path) -> dict[str, str]:
    package = read_package_json(root)
    deps: dict[str, str] = {}
    for key in ("dependencies", "devDependencies", "peerDependencies", "optionalDependencies"):
        for name, version in package.get(key, {}).items():
            deps[name] = version
    return dict(sorted(deps.items()))


def safe_package_filename(name: str) -> str:
    return name.replace("@", "").replace("/", "__")


def npm_metadata(root: Path, package: str) -> dict:
    if not shutil.which("npm"):
        return {}
    proc = run(["npm", "view", package, "--json"], root)
    if proc.returncode != 0 or not proc.stdout.strip():
        return {}
    try:
        data = json.loads(proc.stdout)
    except Exception:
        return {}
    repo = data.get("repository")
    if isinstance(repo, dict):
        repo_url = repo.get("url", "")
    else:
        repo_url = str(repo or "")
    return {
        "latest": data.get("version"),
        "homepage": data.get("homepage"),
        "repository": repo_url.replace("git+", "").replace("git://", "https://").replace(".git", ""),
        "npm": f"https://www.npmjs.com/package/{package}",
        "description": data.get("description"),
        "license": data.get("license"),
    }


def ensure_gitignore_entries(root: Path, entries: list[str]) -> None:
    path = root / ".gitignore"
    lines = path.read_text(errors="ignore").splitlines() if path.exists() else []
    changed = False
    for entry in entries:
        if entry not in lines:
            lines.append(entry)
            changed = True
    if changed or not path.exists():
        path.write_text("\n".join(lines) + "\n")


def command_opensrc(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    deps = package_dependencies(root)
    opensrc = root / "opensrc"
    packages_dir = opensrc / "packages"
    packages_dir.mkdir(parents=True, exist_ok=True)
    ensure_gitignore_entries(root, ["opensrc/"])

    manifest = {
        "generatedAt": now(),
        "root": str(root),
        "packageJsonSha256": sha256_file(root / "package.json") if (root / "package.json").exists() else None,
        "sourcePolicy": "Use official source-of-truth docs/repos only. Fill package files using web/search against official docs, GitHub repos, npm package pages, or framework docs.",
        "packages": [],
    }

    selected = list(deps.items())
    if args.limit:
        selected = selected[: args.limit]

    for name, declared in selected:
        meta = npm_metadata(root, name) if args.fetch_metadata else {}
        item = {
            "name": name,
            "declaredVersion": declared,
            "latest": meta.get("latest"),
            "homepage": meta.get("homepage"),
            "repository": meta.get("repository"),
            "npm": meta.get("npm", f"https://www.npmjs.com/package/{name}"),
            "description": meta.get("description"),
            "license": meta.get("license"),
            "contextFile": f"packages/{safe_package_filename(name)}.md",
            "status": "stub",
        }
        manifest["packages"].append(item)
        package_file = packages_dir / f"{safe_package_filename(name)}.md"
        if not package_file.exists() or args.force:
            package_file.write_text(
                "\n".join([
                    f"# {name}",
                    "",
                    f"- Declared version: `{declared}`",
                    f"- Latest version: `{item['latest'] or 'unknown'}`",
                    f"- npm: {item['npm']}",
                    f"- Homepage: {item['homepage'] or 'unknown'}",
                    f"- Repository: {item['repository'] or 'unknown'}",
                    "",
                    "## Source-Of-Truth Context",
                    "",
                    "Use web/search to fill this file from official docs, the official repository, npm package docs, or framework documentation.",
                    "",
                    "## Key APIs Used In This Project",
                    "",
                    "- Pending.",
                    "",
                    "## Patterns And Constraints",
                    "",
                    "- Pending.",
                    "",
                    "## Version Notes",
                    "",
                    "- Pending.",
                    "",
                ]) + "\n"
            )

    (opensrc / "manifest.json").write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n")
    readme = opensrc / "README.md"
    if not readme.exists() or args.force:
        readme.write_text(
            "# opensrc\n\n"
            "Project-local source-of-truth library context for agents.\n\n"
            "This directory is intentionally gitignored. It should contain copied/summarized context from official docs, official repositories, npm package pages, or framework docs.\n\n"
            "Run:\n\n"
            "```bash\n"
            "mct opensrc --fetch-metadata\n"
            "```\n\n"
            "Then fill `packages/*.md` using web/search against official sources only.\n"
        )

    print(json.dumps({
        "ok": True,
        "opensrc": str(opensrc),
        "packages": len(manifest["packages"]),
        "gitignore": "opensrc/",
        "manifest": str(opensrc / "manifest.json"),
    }, indent=2))
    return 0


def command_audit(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    data = status_data(root)
    issues: list[dict] = []
    state = data["state"]
    runs = state.get("runs", [])
    checks = state.get("checkHistory", [])
    receipts = load_receipts(root)
    receipt_task_ids = {
        task_id_value
        for _, receipt in receipts
        for task_id_value in receipt.get("completedTasks", [])
    }
    receipt_by_task = {
        task_id_value: receipt
        for _, receipt in receipts
        for task_id_value in receipt.get("completedTasks", [])
    }

    if data["packageJson"] and not data["opensrc"]["manifest"]:
        issues.append({
            "severity": "high",
            "code": "opensrc-missing",
            "message": "package.json exists but opensrc/manifest.json is missing. Run mct opensrc --fetch-metadata before normal MCT work.",
        })
    elif data["packageJson"]:
        coverage = opensrc_package_coverage(root)
        if coverage["missingPackages"]:
            issues.append({
                "severity": "high",
                "code": "opensrc-incomplete-package-coverage",
                "message": "opensrc/manifest.json does not cover every declared package: " + ", ".join(coverage["missingPackages"]),
            })
        if coverage["missingContextFiles"]:
            issues.append({
                "severity": "high",
                "code": "opensrc-context-files-missing",
                "message": "opensrc package entries are missing context files: " + ", ".join(coverage["missingContextFiles"]),
            })
        if coverage["stubContextFiles"]:
            preview = ", ".join(coverage["stubContextFiles"][:12])
            remaining = len(coverage["stubContextFiles"]) - 12
            suffix = "" if remaining <= 0 else f" and {remaining} more"
            issues.append({
                "severity": "medium",
                "code": "opensrc-context-still-stubbed",
                "message": "opensrc context files still contain stub placeholders. Fill task-relevant official docs before editing; remaining stubs: " + preview + suffix,
            })

    open_tasks = [task for task in data["tasks"] if not task["done"]]
    if data["todo"] and open_tasks and not data["plan"].get("next"):
        issues.append({
            "severity": "medium",
            "code": "todo-no-runnable-task",
            "message": "TODO.md has open tasks but no runnable next task. Check blockers, missing dependencies, or cycles.",
        })

    if data["todo"] and not runs:
        issues.append({
            "severity": "medium",
            "code": "no-receipts",
            "message": "TODO.md exists but no MCT receipts were recorded. Completed tasks should use mct done with checks.",
        })

    for task_data in data["tasks"]:
        if not task_data["done"]:
            continue
        task = TodoTask(**task_data)
        receipt = receipt_by_task.get(task.id)
        if not receipt:
            issues.append({
                "severity": "high",
                "code": "checked-todo-without-receipt",
                "message": f"TODO item is checked but has no matching receipt: {task.clean_text}",
            })
            continue
        receipt_evidence = receipt.get("browserEvidence", []) or []
        artifact_ok = browser_artifact_ok(root, receipt_evidence)[0] if receipt_evidence else False
        executed = receipt.get("executedChecks", []) or []
        missing = unmet_required_checks(
            task, root, receipt.get("checksRun", []), receipt.get("checksSkipped", []), executed, artifact_ok
        )
        if missing:
            issues.append({
                "severity": "high",
                "code": "completed-todo-missing-required-checks",
                "message": f"Completed TODO is missing required checks ({', '.join(missing)}): {task.clean_text}",
            })
        commit = receipt.get("commit") or state.get("tasks", {}).get(task.id, {}).get("commit")
        if load_config(root).get("verification", {}).get("requireCommitForTodoWorkflow", True):
            if not commit:
                issues.append({
                    "severity": "medium",
                    "code": "completed-todo-without-commit",
                    "message": f"Completed TODO has a receipt but no commit SHA: {task.clean_text}",
                })
            elif not commit_exists(root, commit.get("sha")):
                issues.append({
                    "severity": "high",
                    "code": "completed-todo-commit-missing",
                    "message": f"Completed TODO references a commit that is not present locally: {task.clean_text}",
                })

    if ("react" in data["surfaces"] or "ui" in data["surfaces"]) and not checks:
        issues.append({
            "severity": "high",
            "code": "ui-verification-missing",
            "message": "React/UI files changed but no check history exists. Run Playwright/Chrome verification, React Doctor, or record an explicit skipped check.",
        })

    recent_check_names = []
    recent_browser_evidence = []
    recent_skipped_checks = []
    for item in checks[-5:]:
        recent_check_names.extend(item.get("checksRun", []))
        recent_browser_evidence.extend(item.get("browserEvidence", []))
        recent_skipped_checks.extend(item.get("checksSkipped", []))
    if ("react" in data["surfaces"] or "ui" in data["surfaces"]) and recent_check_names:
        browser_checked = bool(browser_check_names(recent_check_names))
        if not browser_checked:
            issues.append({
                "severity": "medium",
                "code": "browser-check-not-recorded",
                "message": "React/UI files changed and checks exist, but no Playwright/Chrome/browser verification was recorded.",
            })
        elif not recent_browser_evidence:
            issues.append({
                "severity": "high",
                "code": "browser-evidence-missing",
                "message": "A browser-style check was recorded for React/UI changes, but no evidence was recorded. Include URL, viewport, command/test, screenshot, and pass result via --browser-evidence.",
            })
        elif not valid_browser_evidence([item.get("raw", "") for item in recent_browser_evidence])[0]:
            issues.append({
                "severity": "high",
                "code": "browser-evidence-too-weak",
                "message": "Browser evidence exists but is too vague or did not pass. Record concrete Playwright/Chrome evidence with target, viewport/test/screenshot, and result=pass.",
            })
        elif browser_artifact_issue(root, recent_browser_evidence):
            issues.append({
                "severity": "high",
                "code": "browser-artifact-missing",
                "message": browser_artifact_issue(root, recent_browser_evidence),
            })
    elif ("react" in data["surfaces"] or "ui" in data["surfaces"]) and recent_skipped_checks:
        explicit_browser_skip = any(re.search(r"(playwright|chrome|browser)", check, re.IGNORECASE) for check in recent_skipped_checks)
        if not explicit_browser_skip:
            issues.append({
                "severity": "medium",
                "code": "browser-skip-not-explicit",
                "message": "React/UI files changed and checks were skipped, but no explicit Playwright/Chrome/browser skipped-check reason was recorded.",
            })

    result = {
        "ok": not issues,
        "root": data["root"],
        "issues": issues,
        "requiredBeforeFinal": [
            "mct start/status used when MCT is requested",
            "opensrc initialized when package.json exists",
            "opensrc manifest covers every declared package from package.json",
            "TODO items checked off with mct done only after verification",
            "Playwright/Chrome/browser check recorded for UI tasks with URL/viewport/test/screenshot evidence when possible",
            "checks/skipped-checks/risks included in final response",
        ],
    }
    print(json.dumps(result, indent=2))
    high_severity = any(issue.get("severity") == "high" for issue in issues)
    if getattr(args, "strict", False):
        # Strict mode always fails on a high-severity issue, regardless of warn-only.
        return 1 if high_severity else 0
    return 0 if result["ok"] or getattr(args, "warn_only", False) else 1


def command_final_check(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    audit_args = argparse.Namespace(warn_only=args.warn_only)
    code = command_audit(audit_args)
    if args.todo_log:
        command_todo_log(argparse.Namespace(md=True))
    return code


def is_react_project(root: Path) -> bool:
    if any((root / name).exists() for name in ("next.config.js", "next.config.mjs", "next.config.ts")):
        return True
    path = root / "package.json"
    if not path.exists():
        return False
    try:
        package = json.loads(path.read_text())
    except Exception:
        return False
    deps = {}
    deps.update(package.get("dependencies", {}))
    deps.update(package.get("devDependencies", {}))
    return "react" in deps or "next" in deps


def run_package_script(root: Path, name: str) -> int:
    if not package_has_script(root, name):
        return 0
    if (root / "pnpm-lock.yaml").exists():
        cmd = ["pnpm", "run", name]
    elif (root / "yarn.lock").exists():
        cmd = ["yarn", name]
    else:
        cmd = ["npm", "run", name]
    return subprocess.run(cmd, cwd=str(root)).returncode


def command_verify(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    files = files_for_verify(root, args.mode)
    surfaces = classify_files(files)
    failures: list[str] = []

    if args.mode == "pre-commit":
        found, reason = has_secret_in_staged(root)
        if found:
            failures.append(reason)

    if "react" in surfaces and is_react_project(root):
        print("MCT verify: React changes detected, running React Doctor diff", file=sys.stderr)
        proc = subprocess.run(["npx", "-y", "react-doctor@latest", ".", "--verbose", "--diff"], cwd=str(root))
        if proc.returncode != 0:
            failures.append("react-doctor-diff failed")

    if args.mode in ("pre-push", "ci") and package_has_script(root, "typecheck"):
        print("MCT verify: running typecheck", file=sys.stderr)
        if run_package_script(root, "typecheck") != 0:
            failures.append("typecheck failed")

    receipt = {
        "at": now(),
        "summary": f"mct verify {args.mode}",
        "completedTasks": [],
        "checksRun": recommend_checks(root, surfaces),
        "checksSkipped": [],
        "risks": failures,
        "changedFiles": git_files(root),
        "stagedFiles": git_files(root, staged=True),
    }
    append_receipt(root, receipt)
    if failures:
        print(json.dumps({"ok": False, "failures": failures, "surfaces": surfaces}, indent=2), file=sys.stderr)
        return 1
    print(json.dumps({"ok": True, "mode": args.mode, "surfaces": surfaces}, indent=2))
    return 0


def ensure_gitignore(root: Path) -> None:
    ensure_gitignore_entries(root, [".mct/", "opensrc/"])


def install_git_hook(root: Path, name: str) -> str:
    source = claude_root() / "git-hooks" / name
    target = root / ".git" / "hooks" / name
    if not source.exists() or not (root / ".git").exists():
        return "skipped"
    if target.exists() and target.read_text(errors="ignore") != source.read_text(errors="ignore"):
        backup = target.with_suffix(target.suffix + f".bak-{datetime.now(timezone.utc).strftime('%Y%m%d%H%M%S')}")
        shutil.copy2(target, backup)
    shutil.copy2(source, target)
    target.chmod(0o755)
    return "installed"


def install_ci(root: Path) -> str:
    workflow_source = claude_root() / "templates" / "ci" / "github-actions" / "mct.yml"
    mct_source = claude_root() / "bin" / "mct"
    if not workflow_source.exists() or not mct_source.exists():
        return "skipped"
    workflow_target = root / ".github" / "workflows" / "mct.yml"
    cli_target = root / ".github" / "mct" / "mct"
    workflow_target.parent.mkdir(parents=True, exist_ok=True)
    cli_target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(workflow_source, workflow_target)
    shutil.copy2(mct_source, cli_target)
    cli_target.chmod(0o755)
    return "installed"


def command_init(args: argparse.Namespace) -> int:
    root = find_root(Path.cwd())
    (root / ".mct").mkdir(exist_ok=True)
    state = load_state(root)
    save_state(root, state)
    result = {"root": str(root), "state": str(state_path(root)), "ok": True}
    if args.project:
        ensure_gitignore(root)
        result["config"] = str(write_config(root, force=args.force_config))
        if not (root / "TODO.md").exists():
            template = claude_root() / "templates" / "docs" / "mct-todo.md"
            if template.exists():
                shutil.copy2(template, root / "TODO.md")
        result["gitignore"] = "updated"
        result["opensrc"] = "available; run mct opensrc --fetch-metadata to initialize library context"
        result["preCommit"] = install_git_hook(root, "pre-commit")
        result["prePush"] = install_git_hook(root, "pre-push")
        if args.ci:
            result["ci"] = install_ci(root)
    print(json.dumps(result, indent=2))
    return 0


def command_self_update(args: argparse.Namespace) -> int:
    root = source_root()
    if not root:
        raise SystemExit(
            "Could not find the skills-hub source repo. Set MCT_SOURCE=/path/to/skills-hub, "
            "or run updates from a cloned skills-hub repo with ./claude/update.sh."
        )
    if not args.no_pull:
        proc = subprocess.run(["git", "pull", "--ff-only"], cwd=str(root))
        if proc.returncode != 0:
            return proc.returncode
    installer = root / "claude" / "install.sh"
    proc = subprocess.run([str(installer)], cwd=str(root))
    if proc.returncode != 0:
        return proc.returncode
    print(json.dumps({
        "ok": True,
        "source": str(root),
        "installedTo": str(claude_root()),
        "nextSteps": [
            "Restart Claude Code sessions for fresh hook context.",
            "Run ~/.claude/bin/mct init --project in projects that use MCT hooks.",
            "Run ~/.claude/bin/mct init --project --ci in projects with vendored MCT CI."
        ]
    }, indent=2))
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(prog="mct", description="My Claude Toolkit orchestration CLI")
    parser.add_argument("--version", action="version", version=VERSION)
    sub = parser.add_subparsers(dest="command", required=True)

    status = sub.add_parser("status")
    status.add_argument("--md", action="store_true")
    status.set_defaults(func=command_status)

    start = sub.add_parser("start")
    start.add_argument("--md", action="store_true")
    start.set_defaults(func=command_start)

    sub.add_parser("plan").set_defaults(func=command_plan)

    config = sub.add_parser("config")
    config.add_argument("--init", action="store_true")
    config.add_argument("--force", action="store_true")
    config.set_defaults(func=command_config)

    next_cmd = sub.add_parser("next")
    next_cmd.add_argument("--claim", action="store_true")
    next_cmd.set_defaults(func=command_next)

    init = sub.add_parser("init")
    init.add_argument("--project", action="store_true")
    init.add_argument("--ci", action="store_true")
    init.add_argument("--force-config", action="store_true")
    init.set_defaults(func=command_init)

    classify = sub.add_parser("classify")
    classify.add_argument("--staged", action="store_true")
    classify.add_argument("files", nargs="*")
    classify.set_defaults(func=command_classify)

    opensrc = sub.add_parser("opensrc")
    opensrc.add_argument("--fetch-metadata", action="store_true", help="Fetch package metadata from npm registry")
    opensrc.add_argument("--force", action="store_true", help="Overwrite existing package context stubs")
    opensrc.add_argument("--limit", type=int)
    opensrc.set_defaults(func=command_opensrc)

    audit = sub.add_parser("audit")
    audit.add_argument("--warn-only", action="store_true")
    audit.add_argument("--strict", action="store_true", help="Exit non-zero on any high-severity issue, regardless of --warn-only")
    audit.set_defaults(func=command_audit)

    final_check = sub.add_parser("final-check")
    final_check.add_argument("--warn-only", action="store_true")
    final_check.add_argument("--todo-log", action="store_true")
    final_check.set_defaults(func=command_final_check)

    browser_proof = sub.add_parser("browser-proof")
    browser_proof.add_argument("--tool", default="playwright-mcp")
    browser_proof.add_argument("--url")
    browser_proof.add_argument("--test")
    browser_proof.add_argument("--command")
    browser_proof.add_argument("--screenshot")
    browser_proof.add_argument("--viewport", default="")
    browser_proof.add_argument("--flow", default="")
    browser_proof.add_argument("--assertion", default="")
    browser_proof.add_argument("--result", default="pass")
    browser_proof.set_defaults(func=command_browser_proof)

    todo_log = sub.add_parser("todo-log")
    todo_log.add_argument("--md", action="store_true")
    todo_log.set_defaults(func=command_todo_log)

    branch = sub.add_parser("branch")
    branch.add_argument("name", nargs="?")
    branch.add_argument("--prefix", default="umar/")
    branch.set_defaults(func=command_branch)

    verify = sub.add_parser("verify")
    verify.add_argument("--mode", choices=["pre-commit", "pre-push", "manual", "ci"], default="manual")
    verify.set_defaults(func=command_verify)

    receipt = sub.add_parser("receipt")
    receipt.add_argument("--summary", default="")
    receipt.add_argument("--completed-task", action="append")
    receipt.add_argument("--check", action="append")
    receipt.add_argument("--skipped-check", action="append")
    receipt.add_argument(
        "--browser-evidence",
        action="append",
        help="Evidence for UI/browser verification, e.g. tool=playwright-mcp | url=http://localhost:3000 | viewport=1440x900,390x844 | result=pass",
    )
    receipt.add_argument("--risk", action="append")
    receipt.set_defaults(func=command_receipt)

    run_check = sub.add_parser("run-check")
    run_check.add_argument("name", nargs="+", help="Checks to execute for real, e.g. typecheck test react-doctor")
    run_check.set_defaults(func=command_run_check)

    done = sub.add_parser("done")
    done.add_argument("task")
    done.add_argument("--summary", default="")
    done.add_argument("--check", action="append")
    done.add_argument("--run-check", action="append", help="Execute a check for real (typecheck/test/react-doctor) and require it to pass")
    done.add_argument("--skipped-check", action="append")
    done.add_argument(
        "--browser-evidence",
        action="append",
        help="Required for UI/browser TODOs unless skipped. Include tool, target URL/test/screenshot, viewport, and result=pass.",
    )
    done.add_argument("--risk", action="append")
    done.add_argument("--commit", action="store_true")
    done.add_argument("--all", action="store_true", help="Stage all changes before committing")
    done.add_argument("--allow-no-commit", action="store_true", help="Do not fail if --commit has no staged changes to commit")
    done.add_argument("--message")
    done.set_defaults(func=command_done)

    commit = sub.add_parser("commit")
    commit.add_argument("--task")
    commit.add_argument("--summary", default="")
    commit.add_argument("--check", action="append")
    commit.add_argument("--skipped-check", action="append")
    commit.add_argument("--all", action="store_true", help="Stage all changes before committing")
    commit.add_argument("--message")
    commit.set_defaults(func=command_commit)

    self_update = sub.add_parser("self-update")
    self_update.add_argument("--no-pull", action="store_true", help="Install from local source without pulling")
    self_update.set_defaults(func=command_self_update)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
